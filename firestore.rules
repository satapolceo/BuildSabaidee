rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Focused source-controlled rules for review-sensitive shared records.
    // This repo previously had no checked-in Firestore rules file, so publish
    // this only after merging it with any broader collection rules already
    // managed in Firebase Console for unrelated collections.

    function isSignedIn() {
      return request.auth != null;
    }

    function authRole() {
      return !isSignedIn()
        ? ''
        : request.auth.token.role is string
          ? request.auth.token.role
          : request.auth.token.admin == true || request.auth.token.platformOwner == true
            ? 'admin'
            : request.auth.token.email == 'admin@buildsabaidee.app'
              ? 'admin'
              : '';
    }

    function isAuthorizedReviewer() {
      return authRole() in [
        'admin',
        'manager',
        'project_manager',
        'site_manager',
        'supervisor',
        'contractor'
      ];
    }

    function workerAccessPath(uid) {
      return /databases/$(database)/documents/workerAccess/$(uid);
    }

    function hasWorkerAccessProfile() {
      return isSignedIn() && exists(workerAccessPath(request.auth.uid));
    }

    function workerAccessProfile() {
      return get(workerAccessPath(request.auth.uid)).data;
    }

    function workerProjectIds() {
      return hasWorkerAccessProfile() && workerAccessProfile().projectIds is list
        ? workerAccessProfile().projectIds
        : [];
    }

    function workerBelongsToProject(projectId) {
      return hasWorkerAccessProfile()
        && projectId is string
        && workerProjectIds().hasAny([projectId]);
    }

    function workerOwnsRecord(workerId) {
      return hasWorkerAccessProfile()
        && workerAccessProfile().workerId is string
        && workerAccessProfile().workerId == workerId;
    }

    function canReadWorkerDocument() {
      return isAuthorizedReviewer()
        || (hasWorkerAccessProfile()
          && (
            workerOwnsRecord(resource.id)
            || workerBelongsToProject(resource.data.assignedSiteId)
            || (resource.data.assignedProjectIds is list && resource.data.assignedProjectIds.hasAny(workerProjectIds()))
          ));
    }

    function canReadProjectDocument(projectId) {
      return isAuthorizedReviewer() || workerBelongsToProject(projectId);
    }

    function canReadProjectScopedRecord(projectId) {
      return isAuthorizedReviewer() || workerBelongsToProject(projectId);
    }

    function validWorkerAccessWrite() {
      return isSignedIn()
        && request.auth.uid == request.resource.id
        && request.resource.data.workerId is string
        && request.resource.data.email is string
        && request.resource.data.projectIds is list
        && request.resource.data.activeProjectId is string;
    }

    function reviewFields() {
      return ['status', 'reviewNote', 'reviewedAt', 'reviewedBy', 'reviewerRole', 'updatedAt'];
    }

    function allowedReviewerRoles() {
      return ['manager', 'admin'];
    }

    function paymentStatuses() {
      return ['pending', 'approved', 'rejected'];
    }

    function milestoneStatuses() {
      return ['submitted', 'approved', 'rejected'];
    }

    function paymentRequestKeys() {
      return [
        'id', 'workerId', 'workerName', 'siteName', 'projectId', 'projectName',
        'amount', 'taskCategory', 'areaZone', 'note', 'requestedAt', 'dateKey',
        'status', 'syncStatus', 'createdAt', 'updatedAt',
        'reviewNote', 'reviewedAt', 'reviewedBy', 'reviewerRole'
      ];
    }

    function milestoneSubmissionKeys() {
      return [
        'id', 'workerId', 'workerName', 'siteName', 'projectId', 'projectName',
        'taskCategory', 'areaZone', 'progress', 'note', 'photos', 'photoCount',
        'submittedAt', 'dateKey', 'status', 'syncStatus', 'createdAt', 'updatedAt',
        'reviewNote', 'reviewedAt', 'reviewedBy', 'reviewerRole'
      ];
    }

    function reviewRoleValueIsValid() {
      return !request.resource.data.keys().hasAny(['reviewerRole']) ||
        request.resource.data.reviewerRole in allowedReviewerRoles();
    }

    function reviewMetadataShapeIsValid() {
      return (!request.resource.data.keys().hasAny(['reviewNote']) || request.resource.data.reviewNote is string) &&
        (!request.resource.data.keys().hasAny(['reviewedBy']) || request.resource.data.reviewedBy is string) &&
        (!request.resource.data.keys().hasAny(['reviewedAt']) || request.resource.data.reviewedAt is int) &&
        reviewRoleValueIsValid();
    }

    function createHasNoReviewFields() {
      return !request.resource.data.keys().hasAny(['reviewNote', 'reviewedAt', 'reviewedBy', 'reviewerRole']);
    }

    function reviewOnlyKeysChanged() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(reviewFields());
    }

    function reviewUpdateChangesSomethingBeyondTimestamp() {
      return !request.resource.data.diff(resource.data).changedKeys().hasOnly(['updatedAt']);
    }

    function paymentStatusTransitionIsValid() {
      return !request.resource.data.diff(resource.data).changedKeys().hasAny(['status']) || (
        request.resource.data.status in paymentStatuses() &&
        request.resource.data.status != resource.data.status
      );
    }

    function milestoneStatusTransitionIsValid() {
      return !request.resource.data.diff(resource.data).changedKeys().hasAny(['status']) || (
        request.resource.data.status in milestoneStatuses() &&
        request.resource.data.status != resource.data.status
      );
    }

    function validPaymentRequestCreate() {
      return request.resource.data.keys().hasOnly(paymentRequestKeys()) &&
        request.resource.data.id == request.resource.id &&
        request.resource.data.workerId is string &&
        request.resource.data.workerName is string &&
        request.resource.data.projectId is string &&
        request.resource.data.projectName is string &&
        request.resource.data.amount is number &&
        request.resource.data.amount >= 0 &&
        request.resource.data.status == 'pending' &&
        createHasNoReviewFields() &&
        reviewMetadataShapeIsValid();
    }

    function validMilestoneSubmissionCreate() {
      return request.resource.data.keys().hasOnly(milestoneSubmissionKeys()) &&
        request.resource.data.id == request.resource.id &&
        request.resource.data.workerId is string &&
        request.resource.data.workerName is string &&
        request.resource.data.projectId is string &&
        request.resource.data.projectName is string &&
        request.resource.data.status == 'submitted' &&
        request.resource.data.photoCount is int &&
        request.resource.data.photoCount >= 0 &&
        createHasNoReviewFields() &&
        reviewMetadataShapeIsValid();
    }

    function validPaymentReviewUpdate() {
      return isAuthorizedReviewer() &&
        reviewOnlyKeysChanged() &&
        reviewUpdateChangesSomethingBeyondTimestamp() &&
        reviewMetadataShapeIsValid() &&
        paymentStatusTransitionIsValid();
    }

    function validMilestoneReviewUpdate() {
      return isAuthorizedReviewer() &&
        reviewOnlyKeysChanged() &&
        reviewUpdateChangesSomethingBeyondTimestamp() &&
        reviewMetadataShapeIsValid() &&
        milestoneStatusTransitionIsValid();
    }

    match /paymentRequests/{requestId} {
      allow read: if canReadProjectScopedRecord(resource.data.projectId);
      allow create: if hasWorkerAccessProfile()
        && workerOwnsRecord(request.resource.data.workerId)
        && workerBelongsToProject(request.resource.data.projectId)
        && validPaymentRequestCreate();
      allow update: if validPaymentReviewUpdate();
      allow delete: if false;
    }

    match /milestoneSubmissions/{submissionId} {
      allow read: if canReadProjectScopedRecord(resource.data.projectId);
      allow create: if hasWorkerAccessProfile()
        && workerOwnsRecord(request.resource.data.workerId)
        && workerBelongsToProject(request.resource.data.projectId)
        && validMilestoneSubmissionCreate();
      allow update: if validMilestoneReviewUpdate();
      allow delete: if false;
    }

    match /workerAccess/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create, update: if validWorkerAccessWrite();
      allow delete: if false;
    }

    match /workers/{workerId} {
      allow read: if canReadWorkerDocument();
      allow create, update: if isAuthorizedReviewer()
        || (hasWorkerAccessProfile() && workerOwnsRecord(workerId));
      allow delete: if false;
    }

    match /projects/{projectId} {
      allow read: if canReadProjectDocument(projectId);
      allow create, update, delete: if isAuthorizedReviewer();
    }

    match /chats/{chatId} {
      allow read: if canReadProjectScopedRecord(resource.data.projectId);
      allow create: if hasWorkerAccessProfile()
        && workerOwnsRecord(request.resource.data.senderId)
        && workerBelongsToProject(request.resource.data.projectId);
      allow update, delete: if isAuthorizedReviewer();
    }

    match /attendance/{recordId} {
      allow read: if canReadProjectScopedRecord(resource.data.projectId);
      allow create: if hasWorkerAccessProfile()
        && workerOwnsRecord(request.resource.data.workerId)
        && workerBelongsToProject(request.resource.data.projectId);
      allow update: if isAuthorizedReviewer();
      allow delete: if false;
    }

    match /photoReports/{reportId} {
      allow read: if canReadProjectScopedRecord(resource.data.projectId);
      allow create: if hasWorkerAccessProfile()
        && workerOwnsRecord(request.resource.data.workerId)
        && workerBelongsToProject(request.resource.data.projectId);
      allow update: if isAuthorizedReviewer()
        || (hasWorkerAccessProfile()
          && workerOwnsRecord(resource.data.workerId)
          && workerBelongsToProject(resource.data.projectId));
      allow delete: if false;
    }

    match /requests/{requestId} {
      allow read: if canReadProjectScopedRecord(resource.data.projectId);
      allow create: if hasWorkerAccessProfile()
        && workerOwnsRecord(request.resource.data.workerId)
        && workerBelongsToProject(request.resource.data.projectId);
      allow update: if isAuthorizedReviewer()
        || (hasWorkerAccessProfile()
          && workerOwnsRecord(resource.data.workerId)
          && workerBelongsToProject(resource.data.projectId));
      allow delete: if false;
    }

    match /siteTickets/{ticketId} {
      allow read: if canReadProjectScopedRecord(resource.data.projectId);
      allow create: if hasWorkerAccessProfile()
        && workerBelongsToProject(request.resource.data.projectId);
      allow update: if isAuthorizedReviewer()
        || (hasWorkerAccessProfile() && workerBelongsToProject(resource.data.projectId));
      allow delete: if false;
    }

    match /dailyReports/{reportId} {
      allow read: if canReadProjectScopedRecord(resource.data.projectId);
      allow create: if hasWorkerAccessProfile()
        && workerOwnsRecord(request.resource.data.workerId)
        && workerBelongsToProject(request.resource.data.projectId);
      allow update: if isAuthorizedReviewer()
        || (hasWorkerAccessProfile()
          && workerOwnsRecord(resource.data.workerId)
          && workerBelongsToProject(resource.data.projectId));
      allow delete: if false;
    }
  }
}
